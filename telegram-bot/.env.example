# ─── Telegram ────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather_here
BOT_USERNAME=arcaneuz_bot

# ─── Webhook (production) ────────────────────────────────
# Leave empty to use long-polling (development)
WEBHOOK_DOMAIN=https://your-domain.com
WEBHOOK_PATH=/webhook

# ─── Internal API ────────────────────────────────────────
PORT=3001
API_SECRET=your_internal_api_secret_here

# ─── Website ─────────────────────────────────────────────
WEBSITE_URL=http://localhost:3000
WEBSITE_API_SECRET=your_website_api_secret_here

# ─── Admin ───────────────────────────────────────────────
ADMIN_CHAT_ID=your_admin_telegram_id_here

# ─── Environment ─────────────────────────────────────────
NODE_ENV=development
