# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/arcane_db?schema=public"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ── IGDB (Twitch OAuth) ───────────────────────────────────────────────────────
# Get credentials at: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your_twitch_client_id
IGDB_CLIENT_SECRET=your_twitch_client_secret

# ── RAWG ──────────────────────────────────────────────────────────────────────
# Get API key at: https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key

# ── Steam ─────────────────────────────────────────────────────────────────────
# Get key at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key

# ── USD → UZS exchange rate ───────────────────────────────────────────────────
USD_TO_UZS=12700

# ── Jackpot ───────────────────────────────────────────────────────────────────
JACKPOT_CONTRIBUTION_PERCENT=2

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Key Encryption (AES-256-GCM) ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# NEVER commit the real value — keep it in a secrets manager
KEY_ENCRYPTION_SECRET=your_64_char_hex_master_key_never_commit_this_value

# ── Key Inventory ─────────────────────────────────────────────────────────────
KEY_LOW_STOCK_THRESHOLD=5     # global default; override per-game in DB
