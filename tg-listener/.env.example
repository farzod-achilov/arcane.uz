# ── Telegram API (личный аккаунт) ─────────────────────────
# Получить на https://my.telegram.org → API development tools
TG_API_ID=
TG_API_HASH=

# Строка сессии — получить одноразово: npm run login
TG_SESSION=

# ── Источник уведомлений ──────────────────────────────────
# Юзернеймы (без @) или ID чатов карточных ботов, через запятую.
# Точное имя видно в профиле бота, который присылает «Perevod na kartu».
SOURCE_CHATS=

# ── Webhook сайта ─────────────────────────────────────────
WEBHOOK_URL=https://arcane.com.uz/api/deposit/sms-hook
# Тот же секрет, что SMS_HOOK_SECRET в .env.local сайта
SMS_HOOK_SECRET=
