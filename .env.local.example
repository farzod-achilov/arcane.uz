# ─────────────────────────────────────────────────────────
# ARCANE.UZ — Environment Variables
# Copy this file to .env.local and fill in your values.
# On the production server secrets live in .env.local too.
#
# ⚠ NEXT_PUBLIC_* are inlined at BUILD time — they must be present
#   when you run `npm run build`, not just at runtime.
# ─────────────────────────────────────────────────────────

# ── REQUIRED — Core ──────────────────────────────────────
# PostgreSQL connection. On prod the DB is named `arcanedb` (owner `arcane`),
# co-located on the same VPS.
DATABASE_URL=postgresql://arcane:PASSWORD@localhost:5432/arcanedb

# NextAuth session signing. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public site URL (also used for callbacks). NEVER an IP.
NEXTAUTH_URL=https://arcane.com.uz

# ── REQUIRED — First admin bootstrap ─────────────────────
# Register this email in the UI, then:
#   curl -H "x-bootstrap-secret: <BOOTSTRAP_SECRET>" https://arcane.com.uz/api/admin/bootstrap
ADMIN_EMAIL=
# Generate: openssl rand -hex 32
BOOTSTRAP_SECRET=

# ── REQUIRED — Game key encryption ───────────────────────
# Encrypts key values at rest. Changing/losing it makes stored keys
# undecryptable. Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ARCANE.UZ <noreply@arcane.com.uz>

# ── Digiseller Integration ───────────────────────────────
# Get these from your Digiseller seller account:
# https://www.digiseller.com/seller/ → API Settings

# Your numeric seller ID (required to enable Digiseller mode)
DIGISELLER_SELLER_ID=

# Your Digiseller API key/password (used to compute SHA-256 signature)
# Find it at: digiseller.com → Account → API Settings
DIGISELLER_API_KEY=

# Digiseller API base URL (don't change unless using proxy)
DIGISELLER_BASE_URL=https://api.digiseller.com/api

# Digiseller storefront base (for purchase links)
DIGISELLER_STORE_URL=https://digiseller.com

# Products per page when fetching catalog (max 500)
DIGISELLER_PAGE_SIZE=50

# ── Currency ─────────────────────────────────────────────
# USD → UZS exchange rate (update when rate changes)
USD_TO_UZS=12700
# Client-side copy (inlined at build time) — keep in sync with USD_TO_UZS
NEXT_PUBLIC_USD_TO_UZS=12700

# ── Cache TTL (seconds) ───────────────────────────────────
DIGI_CACHE_PRODUCTS_TTL=300
DIGI_CACHE_PRODUCT_TTL=600

# ── Sync Security ─────────────────────────────────────────
# Optional secret header for POST /api/digiseller/sync
# Leave empty to allow unauthenticated sync from admin panel
SYNC_SECRET=

# ── Steam OAuth ──────────────────────────────────────────
# Get at: https://steamcommunity.com/dev/apikey (domain: arcane.com.uz)
STEAM_API_KEY=

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram Login Widget — bot numeric ID (the part before ":" in BOT_TOKEN)
# Also register your domain via BotFather: /setdomain → arcane.com.uz
NEXT_PUBLIC_TELEGRAM_BOT_ID=

# ── ARCANE API (backend) ──────────────────────────────────
# URL of the arcane-api Express backend (server-side only)
ARCANE_API_URL=http://localhost:4000

# Service token — admin JWT from arcane-api for server→server calls
# Generate by logging in via POST /api/auth/login with isAdmin=true user
ARCANE_SERVICE_TOKEN=

# ── App URL (used for referral links, emails, etc.) ──────
# Set this to your public domain — NEVER use an IP address here
NEXT_PUBLIC_APP_URL=https://arcane.com.uz

# ── RAWG API ──────────────────────────────────────────────
# Free registration at https://rawg.io/apidocs
# Provides game metadata, ratings, screenshots, platform info
RAWG_API_KEY=

# ── IGDB API (via Twitch) ─────────────────────────────────
# 1. Create app at https://dev.twitch.tv/console/apps
# 2. Category: "Application Integration"
# 3. Add OAuth Redirect URL: http://localhost
# Provides screenshots, trailers (YouTube), detailed metadata
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Market Price APIs (Supplier auto-fetch) ───────────────
# Kinguin partner API key — enables auto-fetch of supplier prices
# Register at: https://www.kinguin.net/integration
KINGUIN_API_KEY=

# Eneba partner API key — enables auto-fetch of supplier prices
# Register at: https://www.eneba.com/partners
ENEBA_API_KEY=
