# ─────────────────────────────────────────────────────────
# ARCANE.UZ — Environment Variables
# Copy this file to .env.local and fill in your values.
# On the production server secrets live in .env.local too.
#
# ⚠ NEXT_PUBLIC_* are inlined at BUILD time — they must be present
#   when you run `npm run build`, not just at runtime.
# ─────────────────────────────────────────────────────────

# ── REQUIRED — Core ──────────────────────────────────────
# PostgreSQL connection. On prod the DB is named `arcanedb` (owner `arcane`),
# co-located on the same VPS.
DATABASE_URL=postgresql://arcane:PASSWORD@localhost:5432/arcanedb

# NextAuth session signing. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public site URL (also used for callbacks). NEVER an IP.
NEXTAUTH_URL=https://arcane.com.uz

# ── REQUIRED — First admin bootstrap ─────────────────────
# Register this email in the UI, then:
#   curl -H "x-bootstrap-secret: <BOOTSTRAP_SECRET>" https://arcane.com.uz/api/admin/bootstrap
ADMIN_EMAIL=
# Generate: openssl rand -hex 32
BOOTSTRAP_SECRET=

# ── REQUIRED — Game key encryption ───────────────────────
# Encrypts key values at rest. Changing/losing it makes stored keys
# undecryptable. Generate: openssl rand -hex 32
KEY_ENCRYPTION_SECRET=

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ARCANE.UZ <noreply@arcane.com.uz>

# ── Digiseller Integration ───────────────────────────────
# Get these from your Digiseller seller account:
# https://www.digiseller.com/seller/ → API Settings

# Your numeric seller ID (required to enable Digiseller mode)
DIGISELLER_SELLER_ID=

# Your Digiseller API key/password (used to compute SHA-256 signature)
# Find it at: digiseller.com → Account → API Settings
DIGISELLER_API_KEY=

# Digiseller API base URL (don't change unless using proxy)
DIGISELLER_BASE_URL=https://api.digiseller.com/api

# Digiseller storefront base (for purchase links)
DIGISELLER_STORE_URL=https://digiseller.com

# Products per page when fetching catalog (max 500)
DIGISELLER_PAGE_SIZE=50

# ── Currency ─────────────────────────────────────────────
# USD → UZS exchange rate (update when rate changes)
USD_TO_UZS=12700
# Client-side copy (inlined at build time) — keep in sync with USD_TO_UZS
NEXT_PUBLIC_USD_TO_UZS=12700

# ── Cache TTL (seconds) ───────────────────────────────────
DIGI_CACHE_PRODUCTS_TTL=300
DIGI_CACHE_PRODUCT_TTL=600

# ── Sync Security ─────────────────────────────────────────
# Optional secret header for POST /api/digiseller/sync
# Leave empty to allow unauthenticated sync from admin panel
SYNC_SECRET=

# ── Feature flags ─────────────────────────────────────────
# Кейсы «в разработке»: раздел виден как тизер («Скоро»), открытие
# отключено (страницы + API). Включено по умолчанию.
# Запустить кейсы: поставить false и пересобрать (NEXT_PUBLIC_* — build time!)
NEXT_PUBLIC_CASES_COMING_SOON=true

# ── P2P-депозиты (перевод на карту) ──────────────────────
# Секрет для webhook /api/deposit/sms-hook — сюда SMS-forwarder
# с телефона (SIM карт из пула) пересылает банковские SMS.
# Пусто = автоподтверждение отключено, работает только ручное.
# Generate: openssl rand -hex 32
SMS_HOOK_SECRET=

# Сколько минут действует заявка на пополнение (таймер на оплату)
DEPOSIT_TTL_MINUTES=10

# ── SkinsBack (оплата скинами CS2/Dota2/Rust) ────────────
# Получить в личном кабинете: https://skinsback.com/signup/
# Пусто = метод скрыт на /deposit, не ломает остальные способы оплаты
SKINSBACK_CLIENT_ID=
SKINSBACK_CLIENT_SECRET=
# Показать вкладку на /deposit (после заполнения секретов выше) — билд-тайм флаг
NEXT_PUBLIC_SKINSBACK_ENABLED=false

# ── @CryptoBot / Crypto Pay (оплата в USDT) ──────────────
# Открыть t.me/CryptoBot → Crypto Pay → Create App, скопировать токен.
# Без бизнес-верификации, аккаунта в Telegram достаточно.
CRYPTOBOT_TOKEN=
# true = t.me/CryptoTestnetBot (тестовые деньги, для проверки перед боем)
CRYPTOBOT_TESTNET=false
# Показать вкладку на /deposit (после заполнения токена выше) — билд-тайм флаг
NEXT_PUBLIC_CRYPTOBOT_ENABLED=false

# ── Steam OAuth ──────────────────────────────────────────
# Get at: https://steamcommunity.com/dev/apikey (domain: arcane.com.uz)
STEAM_API_KEY=

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram Login Widget — bot numeric ID (the part before ":" in BOT_TOKEN)
# Also register your domain via BotFather: /setdomain → arcane.com.uz
NEXT_PUBLIC_TELEGRAM_BOT_ID=

# ── ARCANE API (backend) ──────────────────────────────────
# URL of the arcane-api Express backend (server-side only)
ARCANE_API_URL=http://localhost:4000

# Service token — admin JWT from arcane-api for server→server calls
# Generate by logging in via POST /api/auth/login with isAdmin=true user
ARCANE_SERVICE_TOKEN=

# ── App URL (used for referral links, emails, etc.) ──────
# Set this to your public domain — NEVER use an IP address here
NEXT_PUBLIC_APP_URL=https://arcane.com.uz

# ── RAWG API ──────────────────────────────────────────────
# Free registration at https://rawg.io/apidocs
# Provides game metadata, ratings, screenshots, platform info
RAWG_API_KEY=

# ── IGDB API (via Twitch) ─────────────────────────────────
# 1. Create app at https://dev.twitch.tv/console/apps
# 2. Category: "Application Integration"
# 3. Add OAuth Redirect URL: http://localhost
# Provides screenshots, trailers (YouTube), detailed metadata
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Market Price APIs (Supplier auto-fetch — search tier only) ──
# Read-only price comparison, used by /api/admin/market-prices.
# NOT used for catalog sync or dropship ordering — see the
# separate "merchant tier" blocks below for that.

# Kinguin partner API key — enables auto-fetch of supplier prices
# Register at: https://www.kinguin.net/integration
KINGUIN_API_KEY=

# Eneba partner API key — enables auto-fetch of supplier prices
# Register at: https://www.eneba.com/partners
ENEBA_API_KEY=

# ── Kinguin Integration (merchant tier — catalog sync + dropship) ─
# Single API key (X-Api-Key header), NOT OAuth2 — verified against
# github.com/kinguinltdhk/Kinguin-eCommerce-API (official reference).
# Get it at: kinguin.net/integration → "APPLY FOR ACCESS" → Kinguin ID
# account → approval → Dashboard → "MY STORES".
# Distinct from KINGUIN_API_KEY above (older, read-only search tier).

KINGUIN_MERCHANT_API_KEY=
# 'sandbox' (default) or 'production' — credentials differ per environment
KINGUIN_MERCHANT_ENV=sandbox
# Verified — don't change unless Kinguin migrates their gateway host
KINGUIN_API_BASE_URL=https://gateway.sandbox.kinguin.net/esa/api

KINGUIN_CACHE_PRODUCTS_TTL=300
KINGUIN_CACHE_PRODUCT_TTL=600

# ── Eneba Integration (merchant tier — catalog sync + dropship) ──
# OAuth2 client_credentials. Distinct from ENEBA_API_KEY above
# (read-only search tier). Docs: https://api.eneba.com/documentation/

ENEBA_AUTH_ID=
ENEBA_AUTH_SECRET=
# 'sandbox' (default) or 'production' — selects the token/API host
ENEBA_MERCHANT_ENV=sandbox

ENEBA_CACHE_PRODUCTS_TTL=300
ENEBA_CACHE_PRODUCT_TTL=600

# ── G2A Integration ⚠ UNVERIFIED ──────────────────────────
# G2A's Integration API docs could not be confirmed live (empty/
# JS-rendered pages on repeated fetch attempts). Setting these
# vars does NOT enable real requests — lib/g2a/auth.ts always
# throws until the real auth scheme is confirmed. See lib/g2a/config.ts.
G2A_CLIENT_ID=
G2A_CLIENT_SECRET=
G2A_API_BASE_URL=https://api.g2a.com/v1

# ── Gamivo Integration ⚠ UNVERIFIED ───────────────────────
# Gamivo's own public API docs are titled "under development".
# Real dropship access needs their separate, manually-approved
# "Wholesale API" (IP whitelist required) — not this basic key.
# Setting these vars does NOT enable real requests — see lib/gamivo/config.ts.
GAMIVO_API_KEY=
GAMIVO_CLIENT_SECRET=
GAMIVO_API_BASE_URL=https://www.gamivo.com/api
