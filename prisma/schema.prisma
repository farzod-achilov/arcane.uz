generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model drop_history {
  id             String        @id
  userId         String
  dropId         String
  rewardId       String
  coinsSpent     Int
  jackpotContrib Int           @default(0)
  createdAt      DateTime      @default(now())
  drop_machines  drop_machines @relation(fields: [dropId], references: [id])
  drop_rewards   drop_rewards  @relation(fields: [rewardId], references: [id])
  users          users         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

model drop_machines {
  id            String         @id
  name          String
  slug          String         @unique
  theme         String
  price         Int
  description   String?
  imageUrl      String?
  animConfig    Json?
  isActive      Boolean        @default(true)
  totalOpened   Int            @default(0)
  featuredOrder Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  drop_history  drop_history[]
  drop_rewards  drop_rewards[]
}

model drop_rewards {
  id            String        @id
  dropId        String
  gameId        String?
  name          String
  type          RewardType
  rarity        Rarity
  dropChance    Float
  sellValue     Int
  metadata      Json?
  imageUrl      String?
  isActive      Boolean       @default(true)
  timesDropped  Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  drop_machines drop_machines @relation(fields: [dropId], references: [id], onDelete: Cascade)
  games         games?        @relation(fields: [gameId], references: [id])
  inventory     inventory[]
  drop_history  drop_history[]

  @@index([dropId])
  @@index([rarity])
}

model game_keys {
  id               String             @id
  gameId           String
  encryptedKey     String
  keyIv            String
  keyTag           String
  keyHash          String             @unique
  status           KeyStatus          @default(AVAILABLE)
  type             KeyType            @default(BOTH)
  reservedFor      String?
  reservedAt       DateTime?
  reserveExpiry    DateTime?
  soldToUserId     String?
  usedAt           DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  games            games              @relation(fields: [gameId], references: [id])
  users            users?             @relation(fields: [soldToUserId], references: [id])
  key_transactions key_transactions[]

  @@index([gameId, status])
  @@index([gameId, type, status])
  @@index([keyHash])
  @@index([reserveExpiry])
  @@index([status])
}

model games {
  id                String         @id
  externalId        String?
  source            String         @default("manual")
  title             String
  slug              String         @unique
  cover             String?
  screenshots       String[]
  description       String?
  genres            String[]
  platforms         String[]
  rating            Float?
  priceUsd          Float?
  priceUzs          Int?
  releaseDate       DateTime?
  developer         String?
  publisher         String?
  deliveryType      DeliveryType   @default(MANUAL)
  productType       ProductType    @default(KEY)
  isActive          Boolean        @default(true)
  stockStore        Int            @default(0)
  stockDrop         Int            @default(0)
  lowStockThreshold Int            @default(5)
  salesCount        Int            @default(0)
  syncedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime
  drop_rewards      drop_rewards[]
  game_keys         game_keys[]
  game_pricing      game_pricing?
  order_items       order_items[]
  wishlists         wishlists[]
  reviews           reviews[]
  discounts         discounts[]

  @@unique([externalId, source])
  @@index([slug])
  @@index([isActive])
  @@index([isActive, createdAt])
  @@index([salesCount])
}

model discounts {
  id          String    @id
  gameId      String
  type        String    @default("flash")
  discountPct Int
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  games       games     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([isActive])
}

model inventory {
  id           String          @id
  userId       String
  rewardId     String
  status       InventoryStatus @default(PENDING)
  claimedAt    DateTime?
  soldAt       DateTime?
  soldFor      Int?
  createdAt    DateTime        @default(now())
  drop_rewards drop_rewards    @relation(fields: [rewardId], references: [id])
  users        users           @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model jackpot {
  id        String   @id
  total     Int      @default(0)
  updatedAt DateTime
}

model jackpot_history {
  id        String   @id
  userId    String
  amount    Int
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model key_transactions {
  id        String             @id
  keyId     String
  userId    String?
  adminId   String?
  type      KeyTransactionType
  note      String?
  metadata  Json?
  createdAt DateTime           @default(now())
  game_keys game_keys          @relation(fields: [keyId], references: [id])
  users     users?             @relation(fields: [userId], references: [id])

  @@index([keyId])
  @@index([type])
  @@index([userId])
}

model live_drops {
  id         String   @id
  userId     String
  username   String
  avatar     String?
  rewardName String
  rarity     Rarity
  dropName   String
  imageUrl   String?
  createdAt  DateTime @default(now())
  users      users    @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model sessions {
  id           String   @id
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model transactions {
  id            String          @id
  userId        String
  type          TransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int
  description   String?
  metadata      Json?
  createdAt     DateTime        @default(now())
  users         users           @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([userId])
  @@index([createdAt])
}

model deposit_requests {
  id        String        @id
  userId    String
  amount    Int
  method    String
  status    DepositStatus @default(PENDING)
  comment   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime
  users     users         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model users {
  id               String             @id
  email            String             @unique
  username         String             @unique
  password         String
  avatar           String?
  level            Int                @default(1)
  xp               Int                @default(0)
  arcCoins         Int                @default(500)
  balanceUzs       Int                @default(0)
  streak           Int                @default(0)
  lastLoginAt      DateTime?
  isAdmin          Boolean            @default(false)
  isBanned         Boolean            @default(false)
  banReason        String?
  totalDrops       Int                @default(0)
  totalSpent       Int                @default(0)
  totalWon         Int                @default(0)
  referralCode     String?            @unique @map("referral_code")
  referredBy       String?            @map("referred_by")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  drop_history     drop_history[]
  game_keys        game_keys[]
  inventory        inventory[]
  jackpot_history  jackpot_history[]
  key_transactions key_transactions[]
  live_drops       live_drops[]
  sessions         sessions[]
  transactions     transactions[]
  deposit_requests deposit_requests[]
  orders           orders[]
  wishlists        wishlists[]
  reviews          reviews[]
  support_tickets  support_tickets[]
  support_messages support_messages[] @relation("SupportMessageAuthor")
  notifications               notifications[]
  password_reset_tokens       password_reset_tokens[]
  steam_users                 steam_users?
  telegram_users              telegram_users?
  daily_quest_completions     daily_quest_completions[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
  @@index([isBanned])
}

model notifications {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  body      String
  href      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum InventoryStatus {
  PENDING
  CLAIMED
  SOLD
}

enum KeyStatus {
  AVAILABLE
  RESERVED
  SOLD
  USED
  DISABLED
}

enum KeyTransactionType {
  IMPORT
  PURCHASE
  DROP_REWARD
  MANUAL_ASSIGN
  DISABLE
  MOVE
  BULK_IMPORT
}

enum KeyType {
  STORE
  DROP
  BOTH
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum RewardType {
  GAME
  COINS
  BOOST
  DISCOUNT
  JACKPOT
}

enum TransactionType {
  DROP_OPEN
  REWARD_SELL
  JACKPOT_WIN
  ADMIN_GRANT
  REFERRAL_BONUS
  STORE_PURCHASE
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

// ═══════════════════════════════════════════════════════
//  SMART PRICING SYSTEM
// ═══════════════════════════════════════════════════════

enum PricingStrategy {
  GLOBAL
  AGGRESSIVE
  COMPETITIVE
  HIGH_PROFIT
  MANUAL
}

enum UsdRoundType {
  POINT_99
  POINT_49
  INTEGER
}

enum UzsRoundType {
  NEAREST_1000
  NEAREST_9000
  NEAREST_99000
}

enum SmartMarkupType {
  PERCENT
  FIXED
}

model price_settings {
  id                          String       @id @default(uuid())
  globalMarkupPercent         Decimal      @db.Decimal(8, 4)  @default(5)
  cheapGamesThreshold         Decimal      @db.Decimal(12, 4) @default(20)
  cheapGamesFixedMarkup       Decimal      @db.Decimal(12, 4) @default(2)
  expensiveGamesPercentMarkup Decimal      @db.Decimal(8, 4)  @default(10)
  autoRoundUsd                Boolean      @default(true)
  usdRoundType                UsdRoundType @default(POINT_99)
  autoRoundUzs                Boolean      @default(true)
  uzsRoundType                UzsRoundType @default(NEAREST_9000)
  minimumProfitUsd            Decimal      @db.Decimal(12, 4) @default(1)
  aggressiveMarkupPercent     Decimal         @db.Decimal(8, 4)  @default(3)
  competitiveMarkupPercent    Decimal         @db.Decimal(8, 4)  @default(8)
  highProfitMarkupPercent     Decimal         @db.Decimal(8, 4)  @default(20)
  defaultStrategy             PricingStrategy @default(GLOBAL)
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
}

model currency_settings {
  id             String   @id @default(uuid())
  exchangeRate   Decimal  @db.Decimal(12, 4) @default(12700)
  autoUpdateRate Boolean  @default(false)
  lastUpdated    DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model game_pricing {
  id                    String          @id @default(uuid())
  gameId                String          @unique
  supplierPriceUsd      Decimal?        @db.Decimal(12, 4)
  steamPriceUsd         Decimal?        @db.Decimal(12, 4)
  steamDiscountPriceUsd Decimal?        @db.Decimal(12, 4)
  finalPriceUsd         Decimal?        @db.Decimal(12, 4)
  finalPriceUzs         Decimal?        @db.Decimal(16, 0)
  youSaveAmount         Decimal?        @db.Decimal(12, 4)
  youSavePercent        Decimal?        @db.Decimal(8, 4)
  marginPercent         Decimal?        @db.Decimal(8, 4)
  customPricingEnabled  Boolean         @default(false)
  customMarkupType      SmartMarkupType?
  customMarkupValue     Decimal?        @db.Decimal(12, 4)
  customFinalPrice      Decimal?        @db.Decimal(12, 4)
  pricingStrategy       PricingStrategy @default(GLOBAL)
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  games                 games           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  pricing_logs          pricing_logs[]

  @@index([pricingStrategy])
}

model pricing_logs {
  id              String       @id @default(uuid())
  gamePricingId   String
  event           String
  previousUsd     Decimal?     @db.Decimal(12, 4)
  newUsd          Decimal?     @db.Decimal(12, 4)
  previousUzs     Decimal?     @db.Decimal(16, 0)
  newUzs          Decimal?     @db.Decimal(16, 0)
  appliedStrategy String?
  appliedRules    Json?
  triggeredBy     String       @default("system")
  createdAt       DateTime     @default(now())
  game_pricing    game_pricing @relation(fields: [gamePricingId], references: [id], onDelete: Cascade)

  @@index([gamePricingId])
  @@index([createdAt])
}

model exchange_rates {
  id        String   @id @default(uuid())
  currency  String   @default("UZS")
  rate      Decimal  @db.Decimal(12, 4)
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@index([currency])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════
//  TELEGRAM BOT
// ═══════════════════════════════════════════════════════

model telegram_users {
  id               String    @id @default(uuid())
  telegramId       BigInt    @unique
  telegramUsername String?
  firstName        String
  userId           String    @unique
  userName         String
  users            users     @relation(fields: [userId], references: [id])
  linkedAt         DateTime  @default(now())
  rewardStreak     Int       @default(0)
  lastRewardClaim  DateTime?
  referralCode     String    @unique
  referredBy       String?
  totalReferrals   Int       @default(0)
  totalCoinsEarned Int       @default(0)
  prefsOrders      Boolean   @default(true)
  prefsCoins       Boolean   @default(true)
  prefsWishlist    Boolean   @default(true)
  prefsDeals       Boolean   @default(true)
  prefsRewards     Boolean   @default(true)
  prefsAdmin       Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([telegramId])
  @@index([userId])
  @@index([referralCode])
}

// ═══════════════════════════════════════════════════════
//  STEAM
// ═══════════════════════════════════════════════════════

model steam_users {
  id          String   @id @default(uuid())
  userId      String   @unique
  steamId     String   @unique
  displayName String
  avatar      String?
  profileUrl  String?
  linkedAt    DateTime @default(now())

  users users @relation(fields: [userId], references: [id])

  @@index([steamId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════
//  BANNERS (homepage promo slider)
// ═══════════════════════════════════════════════════════

model banners {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  buttonText  String?
  buttonLink  String?
  imageUrl    String?
  badgeText   String?
  colorFrom   String   @default("#7C3AED")
  colorTo     String   @default("#06B6D4")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ═══════════════════════════════════════════════════════
//  DAILY QUESTS
// ═══════════════════════════════════════════════════════

model daily_quest_completions {
  id        String   @id @default(uuid())
  userId    String
  questId   String
  date      String   // YYYY-MM-DD — for daily reset
  reward    Int
  createdAt DateTime @default(now())

  users users @relation(fields: [userId], references: [id])

  @@unique([userId, questId, date])
  @@index([userId, date])
}

model pending_tokens {
  token     String   @id
  userId    String
  userName  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Delivery System ───────────────────────────────────────────────────────────

enum DeliveryType {
  AUTO
  MANUAL
}

enum ProductType {
  KEY
  GIFT
  ACCOUNT
}

// ── Order System ──────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  WAITING_MANUAL
  COMPLETED
  CANCELLED
}

model orders {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  totalPrice   Int         @map("total_price")
  status       OrderStatus @default(PENDING)
  deliveredAt  DateTime?   @map("delivered_at")
  deliveredBy  String?     @map("delivered_by")
  deliveryNote String?     @map("delivery_note")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  user          users           @relation(fields: [userId], references: [id])
  items         order_items[]
  delivery_logs delivery_logs[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model order_items {
  id          String    @id @default(cuid())
  orderId     String    @map("order_id")
  gameId      String    @map("game_id")
  price       Int
  keyValue    String?   @map("key_value")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  order orders @relation(fields: [orderId], references: [id], onDelete: Cascade)
  game  games  @relation(fields: [gameId], references: [id])

  @@index([orderId])
}

model wishlists {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  gameId           String   @map("game_id")
  notifiedPrice    Int?     @map("notified_price")
  createdAt        DateTime @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  game games @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
}

model reviews {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  gameId      String   @map("game_id")
  rating      Int
  body        String?
  authorName  String?  @map("author_name")
  authorEmail String?  @map("author_email")
  verified    Boolean  @default(false)
  isApproved  Boolean  @default(false) @map("is_approved")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user users? @relation(fields: [userId], references: [id], onDelete: Cascade)
  game games  @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([rating])
  @@index([isApproved])
}

// ── Promo Codes ───────────────────────────────────────────────────────────────

enum PromoType {
  PERCENT
  FIXED
}

model promo_codes {
  id        String    @id @default(cuid())
  code      String    @unique
  type      PromoType @default(PERCENT)
  value     Int
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

// ── Support System ────────────────────────────────────────────────────────────

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model support_tickets {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  category  String         @default("other")
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(MEDIUM)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user     users              @relation(fields: [userId], references: [id])
  messages support_messages[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model support_messages {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  isAdmin   Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  ticket support_tickets @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author users           @relation("SupportMessageAuthor", fields: [authorId], references: [id])

  @@index([ticketId])
}

model delivery_logs {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  actor     String   @default("system")
  action    String
  note      String?
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  order orders @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// ── Password Reset ─────────────────────────────────────────────────────────────

model password_reset_tokens {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
