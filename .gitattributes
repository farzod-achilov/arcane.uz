# Force LF for files that run on the Linux server — CRLF breaks bash shebangs
# and config parsers regardless of the committer's OS / core.autocrlf setting.
*.sh        text eol=lf
deploy/**   text eol=lf
*.conf      text eol=lf
ecosystem.config.js text eol=lf

# Let git auto-detect the rest
* text=auto
