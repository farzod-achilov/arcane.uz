# ─────────────────────────────────────────────────────────────────────────────
# ARCANE.UZ — production secrets template
#
# Copy to `.env.production.local` ON THE SERVER and fill in real values.
# `.env.production.local` is gitignored — NEVER commit real secrets.
# (`.env.production`, already committed, holds only non-secret prod overrides.)
#
# ⚠ NEXT_PUBLIC_* are inlined at BUILD time. They must be present when you run
#   `npm run build` on the server — setting them only at runtime has no effect.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — core ──────────────────────────────────────────────────────────
# Local Postgres on the same VPS. Use a strong DB password.
DATABASE_URL=postgresql://arcane:CHANGE_ME_STRONG_PASSWORD@localhost:5432/arcane_db

# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_random_32_bytes
NEXTAUTH_URL=https://arcane.com.uz
NEXT_PUBLIC_APP_URL=https://arcane.com.uz

# ── REQUIRED — first admin bootstrap ─────────────────────────────────────────
# Register this email in the UI first, then call:
#   curl -H "x-bootstrap-secret: <BOOTSTRAP_SECRET>" https://arcane.com.uz/api/admin/bootstrap
ADMIN_EMAIL=farzodachilov27@gmail.com
# Generate with:  openssl rand -hex 32
BOOTSTRAP_SECRET=CHANGE_ME_random_hex

# ── REQUIRED — encryption of game keys ───────────────────────────────────────
# Used to encrypt key values at rest. Losing/changing this makes stored keys
# undecryptable. Generate with:  openssl rand -hex 32
KEY_ENCRYPTION_SECRET=CHANGE_ME_random_hex

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=ARCANE.UZ <noreply@arcane.com.uz>

# ── Telegram (admin notifications + login widget) ────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
NEXT_PUBLIC_TELEGRAM_BOT_ID=123456789

# ── Pricing (USD → UZS) ──────────────────────────────────────────────────────
USD_TO_UZS=12700
NEXT_PUBLIC_USD_TO_UZS=12700

# ── OPTIONAL — external catalog sources (omit → mock/empty fallback) ─────────
# Digiseller
DIGISELLER_SELLER_ID=
DIGISELLER_API_KEY=
DIGISELLER_BASE_URL=https://api.digiseller.com/api
DIGISELLER_STORE_URL=https://digiseller.com
DIGISELLER_PAGE_SIZE=50
DIGI_CACHE_PRODUCTS_TTL=300
DIGI_CACHE_PRODUCT_TTL=600

# Game metadata enrichment
RAWG_API_KEY=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
STEAM_API_KEY=
KINGUIN_API_KEY=
ENEBA_API_KEY=

# Protects POST /api/digiseller/sync for cron/CI (admin session also works).
# Generate with:  openssl rand -hex 16
SYNC_SECRET=

# ── OPTIONAL — separate Arcane pricing/bot microservices ─────────────────────
ARCANE_API_URL=
ARCANE_SERVICE_TOKEN=
TELEGRAM_API_SECRET=
TELEGRAM_BOT_URL=
